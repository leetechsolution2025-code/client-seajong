{
  "name": "client-seajong",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "rm -f .next/dev/lock && NODE_OPTIONS='--max-http-header-size=65536' next dev",
    "dev:clean": "pkill -f 'next dev' 2>/dev/null; sleep 1; rm -f .next/dev/lock; NODE_OPTIONS='--max-http-header-size=65536' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "setup": "npx prisma db push --accept-data-loss && npx tsx prisma/seed.ts && node prisma/seed-departments.js && node prisma/seed-company-info.js && node prisma/seed-branches.js && node prisma/seed-categories.js && node prisma/seed-admin.js",
    "start:fresh": "npm install && npm run setup && npm run dev"
  },
  "dependencies": {
    "@google/genai": "^1.46.0",
    "@google/generative-ai": "^0.24.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/client": "^6.19.2",
    "apexcharts": "^5.10.4",
    "bcryptjs": "^3.0.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.37.0",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^1.14.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.19.2",
    "react": "19.2.3",
    "react-apexcharts": "^2.1.0",
    "react-dom": "19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "ngrok": "^5.0.0-beta.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}