import { NextResponse } from "next/server";
import { getServerSession } from "next-auth";
import { authOptions } from "@/lib/auth";
import { prisma } from "@/lib/prisma";

export async function GET() {
  try {
    const session = await getServerSession(authOptions);
    if (!session) return NextResponse.json({ error: "Unauthorized" }, { status: 401 });

    const warehouses = await prisma.warehouse.findMany({
      select: { id: true, name: true, code: true, type: true }
    });

    const mappedWarehouses = warehouses.map((w: any) => {
      let type = w.type;
      if (w.code === "KVP") type = "MATERIAL";
      else if (w.code === "KHO-THANHPHAM") type = "PRODUCT";
      else if (w.code === "KHO-LOI") type = "DEFECT";
      else if (w.code === "KHO-CHINH") type = "PRODUCT_SYNC";
      return { ...w, type };
    });

    return NextResponse.json(mappedWarehouses);
  } catch (e) {
    console.error("[GET /api/finance/warehouses]", e);
    return NextResponse.json([], { status: 500 });
  }
}
