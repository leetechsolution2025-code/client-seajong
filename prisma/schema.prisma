generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CompanyInfo {
  id        String   @id @default(cuid())
  name      String
  shortName String
  logoUrl   String?
  slogan    String?
  address   String?
  phone     String?
  email     String?
  website   String?
  taxCode   String?
  legalRep  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SeajongCategory {
  id       Int              @id @default(autoincrement())
  name     String
  slug     String
  count    Int              @default(0)
  parent   Int              @default(0)
  syncedAt DateTime         @default(now())
  products SeajongProduct[] @relation("ProductCategories")
}

model SeajongProduct {
  id          Int               @id @default(autoincrement())
  slug        String            @unique
  url         String
  name        String
  excerpt     String            @default("")
  description String            @default("")
  images      String            @default("[]")
  specs       String            @default("{}")
  price       Float             @default(0)
  updatedAt   DateTime
  syncedAt    DateTime          @default(now())
  imageUrl    String?
  categories  SeajongCategory[] @relation("ProductCategories")
}

model SeajongSyncLog {
  id          String    @id @default(cuid())
  status      String
  message     String    @default("")
  totalSynced Int       @default(0)
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
}

model LogisticsSyncLog {
  id         String    @id @default(cuid())
  status     String
  message    String    @default("")
  current    Int       @default(0)
  total      Int       @default(0)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
}

model Client {
  id        String     @id @default(cuid())
  name      String
  shortName String     @unique
  domain    String?    @unique
  logoUrl   String?
  config    String?
  status    String     @default("active")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  address   String?
  slogan    String?
  email     String?
  legalRep  String?
  phone     String?
  taxCode   String?
  employees Employee[]
  users     User[]
  modules   Module[]   @relation("ClientToModule")
}

model User {
  id                   String                @id @default(cuid())
  email                String                @unique
  password             String
  name                 String?
  role                 String                @default("USER")
  permissions          String                @default("[]")
  deptAccess           String                @default("[]")
  clientId             String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  employee             Employee?
  scorecards           InterviewScorecard[]
  mentoredProbations   EmployeeProbation[]   @relation("ProbationMentor")
  approvedYearlyPlans  MarketingYearlyPlan[] @relation("PlanApprover")
  marketingPlans       MarketingYearlyPlan[]
  sentMessages         Message[]             @relation("MessageSender")
  messageParticipants  MessageParticipant[]
  createdNotifications Notification[]        @relation("NotificationCreator")
  recruitmentRequests  RecruitmentRequest[]  @relation("UserRequests")
  client               Client?               @relation(fields: [clientId], references: [id])
}

model Employee {
  id                       String                    @id @default(cuid())
  branchCode               String?
  code                     String                    @unique
  fullName                 String
  gender                   String                    @default("male")
  birthDate                DateTime?
  nationalId               String?
  nationalIdDate           DateTime?
  nationalIdPlace          String?
  permanentAddress         String?
  currentAddress           String?
  phone                    String?
  workEmail                String                    @unique
  personalEmail            String?
  emergencyName            String?
  emergencyRelation        String?
  emergencyPhone           String?
  departmentCode           String
  departmentName           String
  position                 String
  level                    String                    @default("staff")
  manager                  String?
  employeeType             String                    @default("official")
  startDate                DateTime?
  workLocation             String                    @default("main")
  contractType             String                    @default("unsigned")
  contractNumber           String?
  contractSignDate         DateTime?
  contractEndDate          DateTime?
  profileStatus            String                    @default("pending")
  socialInsuranceNumber    String?
  taxCode                  String?
  baseSalary               Float?
  mealAllowance            Float?
  fuelAllowance            Float?
  phoneAllowance           Float?
  seniorityAllowance       Float?
  bankAccount              String?
  bankName                 String?
  bankBranch               String?
  dependents               Int                       @default(0)
  skills                   String?
  softSkills               String?
  education                String?
  certifications           String?
  annualLeave              Int                       @default(12)
  workShift                String                    @default("standard")
  notes                    String?
  status                   String                    @default("active")
  isInsuranceEnrolled      Boolean                   @default(false)
  clientId                 String?
  userId                   String?                   @unique
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  avatarUrl                String?
  attendances              Attendance[]
  contracts                Contract[]                @relation("ContractEmployee")
  customers                Customer[]
  careHistories            CustomerCareHistory[]     @relation("CareHistoryEmployee")
  client                   Client?                   @relation(fields: [clientId], references: [id])
  user                     User?                     @relation(fields: [userId], references: [id])
  employmentHistory        EmploymentHistory[]       @relation("EmploymentHistory")
  hrAssetHandovers         HrAssetHandover[]
  hrSupplyRequests         HrSupplyRequest[]
  insuranceBenefits        InsuranceBenefit[]
  insuranceChanges         InsuranceChange[]
  insuranceHistory         InsuranceHistory[]
  laborContracts           LaborContract[]           @relation("LaborContracts")
  payrolls                 Payroll[]
  personalRequests         PersonalRequest[]         @relation("EmployeePersonalRequests")
  promotionRequestsSent    PromotionRequest[]        @relation("PromotionRequester")
  promotionRequests        PromotionRequest[]        @relation("PromotionRequests")
  promotionInterviews      PromotionRequest[]        @relation("PromotionInterviewer")
  quotations               Quotation[]               @relation("QuotationEmployee")
  retailInvoices           RetailInvoice[]           @relation("RetailInvoiceEmployee")
  salaryAdjustmentsSent    SalaryAdjustmentRequest[] @relation("SalaryAdjustmentRequester")
  salaryAdjustmentRequests SalaryAdjustmentRequest[] @relation("SalaryAdjustmentRequests")
  terminationRequests      TerminationRequest[]      @relation("TerminationRequests")
  probation                EmployeeProbation?
  attendanceConfirmations  AttendanceConfirmation[]
  payrollConfirmations     PayrollConfirmation[]
}

model LaborContract {
  id             String    @id @default(cuid())
  employeeId     String
  contractNumber String    @unique
  contractType   String
  signDate       DateTime?
  startDate      DateTime
  endDate        DateTime?
  baseSalary     Float?
  allowances     String?
  status         String    @default("active")
  attachments    String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  employee       Employee  @relation("LaborContracts", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model EmploymentHistory {
  id             String   @id @default(cuid())
  employeeId     String
  type           String
  oldPosition    String?
  newPosition    String?
  oldDept        String?
  newDept        String?
  oldLevel       String?
  newLevel       String?
  effectiveDate  DateTime
  decisionNumber String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  employee       Employee @relation("EmploymentHistory", fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeProbation {
  id              String    @id @default(cuid())
  employeeId      String    @unique
  mentorId        String?
  startDate       DateTime
  endDate         DateTime
  status          String    @default("ONBOARDING") // ONBOARDING, ON_TRACK, EVALUATING, PASSED, EXTENDED, FAILED
  progress        Int       @default(0)
  
  // Evaluation fields
  midTermReview   String?
  finalReview     String?
  selfEvaluation  String?
  
  // Scoring
  scoreKnowledge  Int?
  scoreSkill      Int?
  scoreAttitude   Int?
  
  notes           String?
  clientId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  mentor          User?     @relation("ProbationMentor", fields: [mentorId], references: [id])
  events          EmployeeProbationEvent[]

  @@index([employeeId])
  @@index([mentorId])
  @@index([status])
}

model EmployeeProbationEvent {
  id              String            @id @default(cuid())
  probationId     String
  title           String
  description     String?
  type            String            @default("EVENT") // EVENT, EVALUATION, MILESTONE
  date            DateTime          @default(now())
  createdAt       DateTime          @default(now())
  
  probation       EmployeeProbation @relation(fields: [probationId], references: [id], onDelete: Cascade)
  
  @@index([probationId])
}

model Payroll {
  id            String    @id @default(cuid())
  nam           Int
  thang         Int
  employeeId    String
  nguonChamCong String    @default("thu-cong")
  ngayCong      Float     @default(0)
  ngayNghiPhep  Float     @default(0)
  ngayNghiKhac  Float     @default(0)
  gioLamThem    Float     @default(0)
  luongCoBan    Float     @default(0)
  phuCap        Float     @default(0)
  thuong        Float     @default(0)
  luongLamThem  Float     @default(0)
  khauTruBH     Float     @default(0)
  thueTNCN      Float     @default(0)
  khauTruKhac   Float     @default(0)
  luongThucNhan Float     @default(0)
  chiPhiCtyDong Float     @default(0)
  tongChiPhiCty Float     @default(0)
  trangThai     String    @default("chua-tra")
  ngayTra       DateTime?
  ghiChu        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  employee      Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, thang, nam])
  @@index([nam, thang])
  @@index([trangThai])
  @@index([employeeId])
}

model Module {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  clients     Client[] @relation("ClientToModule")
}

model DepartmentCategory {
  id                String                        @id @default(cuid())
  code              String                        @unique
  nameVi            String
  nameEn            String
  group             String
  icon              String?
  description       String?
  sortOrder         Int                           @default(0)
  isActive          Boolean                       @default(true)
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt
  stationeryBudget  HrStationeryDepartmentBudget?
  hrStationeryNorms HrStationeryNorm[]
  hrSupplyRequests  HrSupplyRequest[]
}

model HrStationeryDepartmentBudget {
  id            String             @id @default(cuid())
  departmentId  String             @unique
  monthlyBudget Float              @default(0)
  updatedAt     DateTime           @updatedAt
  department    DepartmentCategory @relation(fields: [departmentId], references: [id])
}

model Category {
  id            String         @id @default(cuid())
  type          String
  code          String
  name          String
  color         String?
  icon          String?
  description   String?
  sortOrder     Int            @default(0)
  isActive      Boolean        @default(true)
  clientId      String?
  parentId      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  parent        Category?      @relation("CategoryParent", fields: [parentId], references: [id])
  children      Category[]     @relation("CategoryParent")
  dinhMucVatTus DinhMucVatTu[]
  materials     MaterialItem[]

  @@unique([type, code])
  @@index([type])
  @@index([isActive])
  @@index([clientId])
  @@index([parentId])
}

model CategoryTypeDef {
  id        String   @id @default(cuid())
  value     String   @unique
  label     String
  icon      String   @default("bi-folder")
  color     String   @default("#6366f1")
  prefix    String   @default("CAT")
  sortOrder Int      @default(0)
  isSystem  Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model Branch {
  id        String         @id @default(cuid())
  code      String         @unique
  name      String
  shortName String?
  address   String?
  phone     String?
  email     String?
  taxCode   String?
  legalRep  String?
  status    String         @default("active")
  sortOrder Int            @default(0)
  clientId  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  latitude  Float?
  longitude Float?
  radius    Int?           @default(200)
  wifiIp    String?
  subnets   BranchSubnet[]
}

model Notification {
  id            String                  @id @default(cuid())
  title         String
  content       String
  type          String                  @default("info")
  priority      String                  @default("normal")
  audienceType  String                  @default("all")
  audienceValue String?
  attachments   String?
  clientId      String?
  createdById   String
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  createdBy     User                    @relation("NotificationCreator", fields: [createdById], references: [id])
  recipients    NotificationRecipient[]
}

model NotificationRecipient {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  isRead         Boolean      @default(false)
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId])
}

model Message {
  id           String               @id @default(cuid())
  content      String
  senderId     String
  clientId     String?
  isDeleted    Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  attachments  String?
  sender       User                 @relation("MessageSender", fields: [senderId], references: [id])
  participants MessageParticipant[]
}

model MessageParticipant {
  id        String    @id @default(cuid())
  messageId String
  userId    String
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
}

model Customer {
  id             String                @id @default(cuid())
  name           String
  address        String?
  nguon          String?
  nhom           String?
  daiDien        String?
  xungHo         String?               @default("Anh")
  chucVu         String?
  dienThoai      String?
  email          String?
  ghiChu         String?
  nguoiChamSocId String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  contracts      Contract[]
  nguoiChamSoc   Employee?             @relation(fields: [nguoiChamSocId], references: [id])
  careHistories  CustomerCareHistory[]
  quotations     Quotation[]
  saleOrders     SaleOrder[]

  @@index([nguon])
  @@index([nhom])
}

model CustomerCareHistory {
  id             String    @id @default(cuid())
  customerId     String
  nguoiChamSocId String?
  ngayChamSoc    DateTime
  hinhThuc       String
  thaiDo         String?
  nhuCau         String?
  nganSach       String?
  thoiGianDauTu  String?
  thanhToan      String?
  nguoiDaiDien   String?
  soDienThoai    String?
  tomTat         String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  nguoiChamSoc   Employee? @relation("CareHistoryEmployee", fields: [nguoiChamSocId], references: [id])
  customer       Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([nguoiChamSocId])
  @@index([ngayChamSoc])
}

model Supplier {
  id                   String                @id @default(cuid())
  code                 String?               @unique
  name                 String
  taxCode              String?
  address              String?
  phone                String?
  email                String?
  website              String?
  contactName          String?
  xungHo               String?
  hanMucNo             Float                 @default(0)
  danhGia              Int                   @default(0)
  trangThai            String                @default("active")
  ghiChu               String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  purchaseOrders       PurchaseOrder[]
  purchaseRequestItems PurchaseRequestItem[]
  categories           SupplierCategory[]

  @@index([trangThai])
}

model SupplierCategory {
  supplierId String
  categoryId String
  category   InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplier   Supplier          @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@id([supplierId, categoryId])
  @@index([categoryId])
}

model SaleOrder {
  id            String    @id @default(cuid())
  code          String?   @unique
  customerId    String?
  ngayDat       DateTime?
  ngayGiao      DateTime?
  trangThai     String    @default("draft")
  tongTien      Float     @default(0)
  daThanhToan   Float     @default(0)
  ghiChu        String?
  nguoiPhuTrach String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  customer      Customer? @relation(fields: [customerId], references: [id])

  @@index([trangThai])
  @@index([customerId])
}

model PurchaseRequest {
  id             String                @id @default(cuid())
  code           String?               @unique
  nguoiYeuCau    String
  donVi          String
  ngayTao        DateTime              @default(now())
  ngayCanCo      DateTime?
  lyDo           String?
  trangThai      String                @default("chua-xu-ly")
  ghiChu         String?
  clientId       String?
  createdById    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  purchaseOrders PurchaseOrder[]
  items          PurchaseRequestItem[]

  @@index([trangThai])
  @@index([donVi])
  @@index([clientId])
}

model PurchaseRequestItem {
  id                  String             @id @default(cuid())
  purchaseRequestId   String
  inventoryItemId     String?
  tenHang             String
  donVi               String?
  soLuong             Float              @default(1)
  donGiaDK            Float              @default(0)
  ghiChu              String?
  sortOrder           Int                @default(0)
  trangThaiXuLy       String             @default("cho-xu-ly")
  supplierId          String?
  purchaseOrderItemId String?            @unique
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id])
  supplier            Supplier?          @relation(fields: [supplierId], references: [id])
  inventoryItem       InventoryItem?     @relation(fields: [inventoryItemId], references: [id])
  purchaseRequest     PurchaseRequest    @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
  @@index([inventoryItemId])
  @@index([trangThaiXuLy])
  @@index([supplierId])
}

model PurchaseOrder {
  id                String              @id @default(cuid())
  code              String?             @unique
  supplierId        String?
  purchaseRequestId String?
  ngayDat           DateTime?
  ngayNhan          DateTime?
  trangThai         String              @default("draft")
  tongTien          Float               @default(0)
  daThanhToan       Float               @default(0)
  ghiChu            String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  purchaseRequest   PurchaseRequest?    @relation(fields: [purchaseRequestId], references: [id])
  supplier          Supplier?           @relation(fields: [supplierId], references: [id])
  items             PurchaseOrderItem[]
  stockMovements    StockMovement[]

  @@index([trangThai])
  @@index([supplierId])
  @@index([purchaseRequestId])
}

model PurchaseOrderItem {
  id                  String               @id @default(cuid())
  purchaseOrderId     String
  inventoryItemId     String?
  tenHang             String
  donVi               String?
  soLuong             Float                @default(1)
  donGia              Float                @default(0)
  thanhTien           Float                @default(0)
  soLuongDaNhan       Float                @default(0)
  ghiChu              String?
  sortOrder           Int                  @default(0)
  inventoryItem       InventoryItem?       @relation(fields: [inventoryItemId], references: [id])
  purchaseOrder       PurchaseOrder        @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseRequestItem PurchaseRequestItem?

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
}

model Expense {
  id          String    @id @default(cuid())
  tenChiPhi   String
  loai        String?
  soTien      Float     @default(0)
  ngayChiTra  DateTime?
  nguoiChiTra String?
  trangThai   String    @default("pending")
  ghiChu      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([loai])
  @@index([trangThai])
}

model Debt {
  id           String    @id @default(cuid())
  type         String
  partnerName  String
  amount       Float     @default(0)
  paidAmount   Float     @default(0)
  dueDate      DateTime?
  interestRate Float?
  status       String    @default("UNPAID")
  description  String?
  referenceId  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type])
  @@index([status])
}

model Asset {
  id                   String            @id @default(cuid())
  code                 String?           @unique
  tenTaiSan            String
  loai                 String?
  ngayMua              DateTime?
  giaTriMua            Float             @default(0)
  giaTriConLai         Float             @default(0)
  soThangKhauHao       Int?              @default(0)
  ngayBatDauKhauHao    DateTime?
  chuKyBaoDuong        Int?              @default(0)
  ngayBaoDuongCuoi     DateTime?
  ngayBaoDuongTiepTheo DateTime?
  trangThai            String            @default("chua-su-dung")
  viTri                String?
  nguoiSuDungId        String?
  donVi                String?
  ghiChu               String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  model                String?
  serialNumber         String?
  hrAssetHandovers     HrAssetHandover[]

  @@index([loai])
  @@index([trangThai])
}

model InventoryCategory {
  id        String              @id @default(cuid())
  name      String              @unique
  code      String?             @unique
  sortOrder Int                 @default(0)
  isActive  Boolean             @default(true)
  parentId  String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  parent    InventoryCategory?  @relation("InvCategoryParent", fields: [parentId], references: [id])
  children  InventoryCategory[] @relation("InvCategoryParent")
  items     InventoryItem[]
  suppliers SupplierCategory[]
}

model Warehouse {
  id             String           @id @default(cuid())
  code           String?          @unique
  name           String
  address        String?
  phone          String?
  type           String           @default("PRODUCT")
  managerId      String?
  isVirtual      Boolean          @default(false)
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  layoutJson     String?
  stocks         InventoryStock[]
  materialStocks MaterialStock[]
  stockCounts    StockCount[]
  movementsTo    StockMovement[]  @relation("MovementTo")
  movementsFrom  StockMovement[]  @relation("MovementFrom")

  @@index([isActive])
}

model InventoryItem {
  id                   String                @id @default(cuid())
  code                 String?               @unique
  tenHang              String
  loai                 String?               @default("hang-hoa")
  brand                String?               @default("Seajong")
  model                String?
  version              String?
  color                String?
  categoryId           String?
  donVi                String?               @default("cái")
  soLuong              Float                 @default(0)
  soLuongMin           Float                 @default(0)
  giaNhap              Float                 @default(0)
  giaBan               Float                 @default(0)
  nhaCungCap           String?
  thongSoKyThuat       String?
  trangThai            String                @default("con-hang")
  webProductId         Int?
  ghiChu               String?
  dinhMucId            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  imageUrl             String?
  dinhMuc              DinhMuc?              @relation(fields: [dinhMucId], references: [id])
  category             InventoryCategory?    @relation(fields: [categoryId], references: [id])
  stocks               InventoryStock[]
  purchaseOrderItems   PurchaseOrderItem[]
  purchaseRequestItems PurchaseRequestItem[]
  retailInvoiceItems   RetailInvoiceItem[]
  movements            StockMovement[]

  @@index([loai])
  @@index([trangThai])
  @@index([categoryId])
  @@index([nhaCungCap])
  @@index([dinhMucId])
}

model MaterialItem {
  id             String          @id @default(cuid())
  code           String?         @unique
  name           String
